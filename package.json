{
  "name": "magic-terminal",
  "displayName": "Magic Terminal",
  "description": "Native VS Code terminals managed from the sidebar",
  "publisher": "magic-terminal",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "magic-terminal-sidebar",
          "title": "Magic Terminal",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "magic-terminal-sidebar": [
        {
          "icon": "$(terminal)",
          "type": "webview",
          "id": "magic-terminal.terminalView",
          "name": "Terminal"
        }
      ]
    },
    "commands": [
      {
        "command": "magic-terminal.toggle",
        "title": "Magic Terminal: Toggle Terminal"
      },
      {
        "command": "magic-terminal.newTerminal",
        "title": "Magic Terminal: New Terminal"
      },
      {
        "command": "magic-terminal.killTerminal",
        "title": "Magic Terminal: Kill Active Terminal"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.61.0",
    "eslint": "^10.5.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0"
  }
}
