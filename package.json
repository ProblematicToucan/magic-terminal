{
  "name": "magic-terminal",
  "displayName": "Magic Terminal",
  "description": "Native VS Code terminals managed from the sidebar",
  "publisher": "ProblematicToucan",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ProblematicToucan/magic-terminal.git"
  },
  "bugs": {
    "url": "https://github.com/ProblematicToucan/magic-terminal/issues"
  },
  "homepage": "https://github.com/ProblematicToucan/magic-terminal#readme",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "sidebar",
    "pty",
    "xterm",
    "magic-terminal"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "magic-terminal-sidebar",
          "title": "Magic Terminal",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "magic-terminal-sidebar": [
        {
          "icon": "$(terminal)",
          "type": "webview",
          "id": "magic-terminal.terminalView",
          "name": "Terminal"
        }
      ]
    },
    "commands": [
      {
        "command": "magic-terminal.toggle",
        "title": "Magic Terminal: Toggle Terminal"
      },
      {
        "command": "magic-terminal.newTerminal",
        "title": "Magic Terminal: New Terminal"
      },
      {
        "command": "magic-terminal.killTerminal",
        "title": "Magic Terminal: Kill Active Terminal"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production && (chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper node_modules/node-pty/prebuilds/darwin-x64/spawn-helper 2>/dev/null || true)",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
