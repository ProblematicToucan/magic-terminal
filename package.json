{
  "name": "magic-terminal",
  "displayName": "Magic Terminal",
  "description": "Terminal in the sidebar with full PTY support",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty"
    ]
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "magic-terminal-sidebar",
          "title": "Magic Terminal",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "magic-terminal-sidebar": [
        {
          "icon": "$(terminal)",
          "type": "webview",
          "id": "magic-terminal.terminalView",
          "name": "Terminal"
        }
      ]
    },
    "commands": [
      {
        "command": "magic-terminal.toggle",
        "title": "Magic Terminal: Toggle Terminal"
      },
      {
        "command": "magic-terminal.newTerminal",
        "title": "Magic Terminal: New Terminal"
      },
      {
        "command": "magic-terminal.killTerminal",
        "title": "Magic Terminal: Kill Active Terminal"
      }
    ],
    "configuration": {
      "title": "Magic Terminal",
      "properties": {
        "magic-terminal.shell": {
          "type": "string",
          "default": "",
          "description": "Path to the shell executable. Uses $SHELL or platform default when empty."
        },
        "magic-terminal.shellArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Shell arguments (e.g. ['-l'] for login shell)."
        },
        "magic-terminal.cwd": {
          "type": "string",
          "default": "",
          "description": "Working directory for new terminals. Uses workspace root or home when empty."
        },
        "magic-terminal.fontFamily": {
          "type": "string",
          "default": "",
          "description": "Font family. Uses editor font when empty."
        },
        "magic-terminal.fontSize": {
          "type": "number",
          "default": 0,
          "description": "Font size in px. Uses editor font size when 0."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.61.0",
    "eslint": "^10.5.0",
    "esbuild": "^0.28.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0"
  }
}
