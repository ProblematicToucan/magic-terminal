{
  "name": "magic-terminal",
  "displayName": "Magic Terminal",
  "description": "Native VS Code terminals managed from the sidebar",
  "publisher": "ProblematicToucan",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ProblematicToucan/magic-terminal.git"
  },
  "bugs": {
    "url": "https://github.com/ProblematicToucan/magic-terminal/issues"
  },
  "homepage": "https://github.com/ProblematicToucan/magic-terminal#readme",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "terminal",
    "sidebar",
    "pty",
    "xterm",
    "magic-terminal"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "magic-terminal-sidebar",
          "title": "Magic Terminal",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "magic-terminal-sidebar": [
        {
          "icon": "$(terminal)",
          "type": "webview",
          "id": "magic-terminal.terminalView",
          "name": "Terminal"
        }
      ]
    },
    "commands": [
      {
        "command": "magic-terminal.toggle",
        "title": "Magic Terminal: Toggle Terminal"
      },
      {
        "command": "magic-terminal.newTerminal",
        "title": "Magic Terminal: New Terminal"
      },
      {
        "command": "magic-terminal.killTerminal",
        "title": "Magic Terminal: Kill Active Terminal"
      },
      {
        "command": "magic-terminal.insertFileReference",
        "title": "Magic Terminal: Insert File Reference"
      }
    ],
    "keybindings": [
      {
        "command": "magic-terminal.insertFileReference",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "postinstall": "node -e \"const fs = require('fs'); const path = require('path'); ['darwin-arm64', 'darwin-x64', 'linux-arm64', 'linux-x64'].forEach(p => { const file = path.join('node_modules', 'node-pty', 'prebuilds', p, 'spawn-helper'); if (fs.existsSync(file)) { fs.chmodSync(file, 0o755); } })\"",
    "strip-prebuilds": "node -e \"const fs=require('fs'),p=require('path'),os=require('os');if(!process.env.CI){const d=p.join('node_modules','node-pty','prebuilds');if(fs.existsSync(d)){const c=os.platform()+'-'+os.arch();fs.readdirSync(d).forEach(f=>{if(f!==c)fs.rmSync(p.join(d,f),{recursive:true})})}}\"",
    "package": "npm run check-types && npm run lint && node esbuild.js --production && npm run postinstall && npm run strip-prebuilds",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@types/ws": "^8.18.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
